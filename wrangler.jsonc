{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "apx-energy",
  "compatibility_date": "2026-06-30",
  // Static-assets-only Worker: serves the Vite build output in ./dist.
  // No "main" Worker script is needed for a plain static site.
  "assets": {
    "directory": "./dist",
    // Single-page app: serve index.html for any unmatched path.
    "not_found_handling": "single-page-application"
  }
}
